---
const {
  title = '',
  description = 'Ihre Holding GmbH ist eine familiengeführte Beteiligungsgesellschaft mit Fokus auf ambulante Pflegedienste.',
  canonical
} = Astro.props;

const brandTitle = 'Ihre Holding GmbH';
const siteTitle = title && title !== brandTitle ? `${title} | ${brandTitle}` : brandTitle;
const canonicalUrl = canonical ? new URL(canonical, Astro.site) : new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ihre Holding GmbH" />

    <link rel="icon" href="/IHO-line-logo.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --teal: #03c3de;
    --teal-dark: #008c9e;
    --teal-light: #a6e7ef;
    --navy: #0E2841;
    --navy-mid: #163e64;
    --white: #ffffff;
    --off-white: #f7f8fa;
    --text-dark: #0E2841;
    --text-mid: #163e64;
    --text-muted: #008c9e;
    --cream: #f5f3ee;
    --cream-muted: #c8c4bc;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'DM Sans', Arial, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    background: var(--white);
    color: var(--text-dark);
    font-family: var(--font-body);
    scroll-behavior: smooth;
    text-rendering: optimizeLegibility;
  }

  body {
    background: var(--white);
    color: var(--text-dark);
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.6;
    margin: 0;
    min-width: 320px;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  button {
    border: 0;
  }

  h1,
  h2,
  h3,
  h4 {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0;
  }

  :focus-visible {
    outline: 2px solid var(--teal);
    outline-offset: 4px;
  }

  .container {
    margin-inline: auto;
    max-width: 1440px;
    padding-inline: clamp(2rem, 7vw, 8rem);
    width: 100%;
  }

  .section {
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .eyebrow {
    color: var(--teal);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    margin: 0;
    text-transform: uppercase;
  }
</style>
