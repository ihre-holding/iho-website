---
const isHome = Astro.url.pathname === '/';
const anchorPrefix = isHome ? '' : '/';
const links = [
  { href: `${anchorPrefix}#nachfolge`, label: 'Nachfolge' },
  { href: `${anchorPrefix}#beratung`, label: 'Beratung' },
  { href: `${anchorPrefix}#kontakt`, label: 'Kontakt' },
  { href: 'https://www.ihre-pflege.de', label: 'Ihre Pflege', external: true }
];
---

<header class:list={['site-nav', { 'is-scrolled': !isHome }]} data-nav data-home={String(isHome)}>
  <div class="site-nav__inner container">
    <a class="logo" href={`${anchorPrefix}#hero`} aria-label="Ihre Holding GmbH Startseite">
      <img class="logo__image" src="/IHO-full-logo.png" alt="Ihre Holding GmbH" />
    </a>

    <button
      class="site-nav__toggle"
      type="button"
      aria-label="Navigation öffnen"
      aria-expanded="false"
      aria-controls="site-nav-links"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="site-nav-links" class="site-nav__links" aria-label="Hauptnavigation" data-menu>
      {
        links.map((link) => (
          <a
            href={link.href}
            {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const nav = document.querySelector('[data-nav]');
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-menu]');

  const syncScrolledState = () => {
    if (nav?.getAttribute('data-home') !== 'true') return;
    nav?.classList.toggle('is-scrolled', window.scrollY > 60);
  };

  syncScrolledState();
  window.addEventListener('scroll', syncScrolledState, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Navigation schließen' : 'Navigation öffnen');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Navigation öffnen');
    });
  });
</script>

<style>
  .site-nav {
    color: var(--text-mid);
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    transition:
      background-color 280ms ease,
      box-shadow 280ms ease;
    z-index: 100;
  }

  .site-nav.is-scrolled {
    background: var(--white);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
  }

  .site-nav.is-scrolled .logo__image {
    transition: opacity 280ms ease, transform 280ms ease;
  }

  .site-nav.is-scrolled .logo:hover .logo__image,
  .site-nav.is-scrolled .logo:focus-visible .logo__image {
    opacity: 0.88;
    transform: scale(1.02);
  }

  .site-nav__inner {
    align-items: center;
    display: flex;
    justify-content: space-between;
    min-height: 78px;
    position: relative;
  }

  .logo {
    display: inline-flex;
    height: 58px;
    overflow: hidden;
    text-decoration: none;
  }

  .logo__image {
    height: 100%;
    object-fit: contain;
    width: auto;
  }

  .site-nav__links {
    align-items: center;
    display: flex;
    gap: clamp(1.2rem, 3vw, 2rem);
  }

  .site-nav__links a {
    color: var(--cream-muted);
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    position: relative;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      color 280ms ease,
      opacity 280ms ease,
      transform 200ms ease;
  }

  .site-nav__links a::after {
    background: var(--teal);
    bottom: -0.35rem;
    content: '';
    height: 1px;
    left: 0;
    position: absolute;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms ease;
    width: 100%;
  }

  .site-nav:not(.is-scrolled) .site-nav__links a::after {
    background: var(--teal-light);
  }

  .site-nav.is-scrolled .site-nav__links a,
  .site-nav__links.is-open a {
    color: var(--text-mid);
    opacity: 1;
  }

  .site-nav:not(.is-scrolled) .site-nav__links a:hover,
  .site-nav:not(.is-scrolled) .site-nav__links a:focus-visible {
    color: var(--teal-light);
  }

  .site-nav.is-scrolled .site-nav__links a:hover,
  .site-nav.is-scrolled .site-nav__links a:focus-visible,
  .site-nav__links.is-open a:hover,
  .site-nav__links.is-open a:focus-visible {
    color: var(--teal);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-nav__links a:hover,
    .site-nav__links a:focus-visible {
      transform: translateY(-1px);
    }
  }

  .site-nav__links a:hover::after,
  .site-nav__links a:focus-visible::after {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-nav.is-scrolled .site-nav__links a {
      animation: nav-link-settle 520ms ease backwards;
    }

    .site-nav.is-scrolled .site-nav__links a:nth-child(1) {
      animation-delay: 0ms;
    }

    .site-nav.is-scrolled .site-nav__links a:nth-child(2) {
      animation-delay: 70ms;
    }

    .site-nav.is-scrolled .site-nav__links a:nth-child(3) {
      animation-delay: 140ms;
    }

    .site-nav.is-scrolled .site-nav__links a:nth-child(4) {
      animation-delay: 210ms;
    }
  }

  @keyframes nav-link-settle {
    0% {
      color: var(--text-mid);
      opacity: 0;
      transform: translateY(6px);
    }

    45% {
      color: var(--teal);
    }

    100% {
      color: var(--text-mid);
      opacity: 1;
      transform: translateY(0);
    }
  }

  .site-nav__toggle {
    background: transparent;
    cursor: pointer;
    display: none;
    height: 42px;
    padding: 0;
    width: 42px;
  }

  .site-nav__toggle span {
    background: var(--teal);
    display: block;
    height: 2px;
    margin: 6px auto;
    width: 24px;
  }

  @media (max-width: 680px) {
    .site-nav__inner {
      min-height: 70px;
    }

    .logo {
      height: 50px;
    }

    .site-nav__toggle {
      display: block;
    }

    .site-nav__links {
      background: var(--white);
      box-shadow: 0 1px 0 rgba(0, 0, 0, 0.08);
      display: flex;
      flex-direction: column;
      gap: 0;
      left: 0;
      opacity: 0;
      padding: 0.75rem clamp(1.5rem, 5vw, 3.5rem) 1rem;
      pointer-events: none;
      position: absolute;
      right: 0;
      top: 100%;
      transform: translateY(-8px);
      transition:
        opacity 250ms ease,
        transform 250ms ease,
        visibility 250ms ease;
      visibility: hidden;
    }

    .site-nav__links.is-open {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
      visibility: visible;
    }

    @media (prefers-reduced-motion: no-preference) {
      .site-nav__links.is-open a {
        animation: nav-link-settle 360ms ease backwards;
      }

      .site-nav__links.is-open a:nth-child(1) {
        animation-delay: 40ms;
      }

      .site-nav__links.is-open a:nth-child(2) {
        animation-delay: 90ms;
      }

      .site-nav__links.is-open a:nth-child(3) {
        animation-delay: 140ms;
      }

      .site-nav__links.is-open a:nth-child(4) {
        animation-delay: 190ms;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .site-nav__links {
        transition: none;
      }

      .site-nav__links a,
      .site-nav.is-scrolled .site-nav__links a,
      .site-nav__links.is-open a {
        animation: none;
      }
    }

    .site-nav__links a {
      padding: 0.9rem 0;
      width: 100%;
    }

    .site-nav.is-scrolled .site-nav__links a,
    .site-nav__links.is-open a {
      color: var(--text-mid);
    }

    .site-nav__links a::after {
      bottom: 0.55rem;
    }
  }
</style>
